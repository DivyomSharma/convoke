generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ATTENDEE
  ORGANIZER
  VOLUNTEER
  SPONSOR
  NGO
  CREATOR
  STARTUP_COMMUNITY
  ADMIN
  COMMUNITY_ADMIN
  STARTUP_FOUNDER
  MENTOR
}

enum EventMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
  CHECKED_IN
}

enum SponsorStage {
  PROSPECTING
  CONTACTED
  REPLIED
  NEGOTIATING
  CONFIRMED
  COMPLETED
}

enum MerchStatus {
  INQUIRY_RECEIVED
  REVIEWING
  QUOTATION_SENT
  PRODUCTION
  SHIPPED
  COMPLETED
}

enum OpportunityType {
  INTERNSHIP
  VOLUNTEER
  AMBASSADOR
  STARTUP_JOB
  CREATOR_COLLAB
  FREELANCE_GIG
  RESEARCH_POSITION
  MENTORSHIP
  CONTEST
  SCHOLARSHIP
}

enum ApplicationStatus {
  APPLIED
  REVIEWING
  SHORTLISTED
  INTERVIEW
  OFFER
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum TicketTypeCategory {
  GENERAL
  EARLY_BIRD
  VIP
  STUDENT
  GROUP
}

enum CertificateType {
  PARTICIPATION
  VOLUNTEER
  ORGANIZER
  SPEAKER
  WINNER
  MENTOR
}

enum NotificationType {
  EVENT_REMINDER
  APPLICATION_UPDATE
  NEW_OPPORTUNITY
  COMMUNITY_INVITE
  EVENT_UPDATE
  SPONSOR_RESPONSE
  MERCH_UPDATE
  SYSTEM_ANNOUNCEMENT
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

model User {
  id            String                 @id @default(cuid())
  clerkId       String?                @unique
  email         String                 @unique
  username      String                 @unique
  name          String
  headline      String?
  imageUrl      String?
  role          UserRole               @default(ATTENDEE)
  profile       Profile?
  bio           String?
  experiences   Experience[]
  educations    Education[]
  projects      Project[]
  memberships         Membership[]
  registrations       Registration[]
  volunteerApps       VolunteerApplication[]
  opportunityApps     OpportunityApplication[]
  eventsSpeaking      EventSpeaker[] @relation("EventSpeakerUser")
  eventsOrganized     Event[]        @relation("EventOrganizerUser")
  certificatesIssued  Certificate[]  @relation("CertificateUser")
  notifications       Notification[]
  bookmarks           Bookmark[]     @relation("UserBookmarks")
  followers           Follow[]       @relation("Followers")
  following           Follow[]       @relation("Follows")
  comments            Comment[]      @relation("UserComments")
  reactions           Reaction[]     @relation("UserReactions")
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
}

model Profile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  headline      String?
  avatarUrl     String?
  bannerUrl     String?
  location      String?
  website       String?
  // Social links
  linkedinUrl   String?
  twitterUrl    String?
  instagramUrl  String?
  youtubeUrl    String?
  githubUrl     String?
  discordHandle String?
  portfolioUrl  String?
  // Skills & badges
  skills        String[]
  badges        String[]
  reputation    Float    @default(0)
  // Stats
  eventsAttended      Int    @default(0)
  eventsOrganized     Int    @default(0)
  volunteerHours      Int    @default(0)
  communitiesJoined   Int    @default(0)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model Experience {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company       String
  position      String
  location      String?
  startsAt      DateTime?
  endsAt        DateTime?
  current       Boolean  @default(false)
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Education {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution   String
  degree        String
  fieldOfStudy  String?
  startsAt      DateTime?
  endsAt        DateTime?
  grade         String?
  activities    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Project {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  url           String?
  technologies  String[]
  startsAt      DateTime?
  endsAt        DateTime?
  visible       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Organization {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  type           String
  description    String?
  website        String?
  avatarUrl      String?
  bannerUrl      String?
  // Stats
  membersCount   Int    @default(0)
  eventsCount    Int    @default(0)
  opportunitiesCount Int @default(0)
  // Relations
  members        Membership[]
  events         Event[]
  opportunities  Opportunity[]
  sponsorLeads   SponsorLead[]
  merchInquiries MerchInquiry[]
  announcements  Announcement[]
  galleries      Gallery[]
  certificates   Certificate[] @relation("OrganizationCertificates")
  eventSponsors  EventSponsor[] @relation("EventSponsorOrganization")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  joinedAt       DateTime     @default(now())
  @@unique([userId, organizationId])
}

model Event {
  id             String                 @id @default(cuid())
  organizationId String
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug           String                 @unique
  title          String
  category       String
  city           String
  mode           EventMode
  startsAt       DateTime
  endsAt         DateTime?
  isPaid         Boolean                @default(false)
  inviteOnly     Boolean                @default(false)
  approvalBased  Boolean                @default(false)
  heroImageUrl   String?
  // Legacy field - prefer relational tables for new development
  blocks         Json?
  // Relations
  registrations  Registration[]
  ticketTypes    TicketType[]
  schedules      EventSchedule[]
  speakers       EventSpeaker[] @relation("EventSpeakerEvent")
  sponsors       EventSponsor[] @relation("EventSponsorEvent")
  volunteerApps  VolunteerApplication[]
  sponsorLeads   SponsorLead[]
  certificates   Certificate[] @relation("CertificateEvent")
  galleries      Gallery[]    @relation("EventGalleries")
  organizerId    String?
  organizer      User?        @relation("EventOrganizerUser", fields: [organizerId], references: [id])
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model TicketType {
  id       String @id @default(cuid())
  eventId  String
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name     String
  category TicketTypeCategory @default(GENERAL)
  priceInr Int    @default(0)
  capacity Int?
  sold     Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Registration {
  id           String             @id @default(cuid())
  userId       String
  eventId      String
  ticketTypeId String?
  status       RegistrationStatus @default(PENDING)
  qrCode       String             @unique
  tags         String[]
  checkedInAt  DateTime?
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  event        Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model EventSchedule {
  id            String   @id @default(cuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  startsAt      DateTime
  endsAt        DateTime
  location      String?
  isBreak       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EventSpeaker {
  id            String   @id @default(cuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade, name: "EventSpeakerEvent")
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull, name: "EventSpeakerUser")
  name          String
  title         String?
  organization  String?
  bio           String?
  avatarUrl     String?
  talkTitle     String?
  talkDescription String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EventSponsor {
  id            String   @id @default(cuid())
  eventId       String
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade, name: "EventSponsorEvent")
  organizationId String?
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull, name: "EventSponsorOrganization")
  companyName   String
  tier          String // e.g., Platinum, Gold, Silver
  benefits      String[]
  logoUrl       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SponsorLead {
  id             String       @id @default(cuid())
  organizationId String
  eventId        String?
  companyName    String
  contactEmail   String
  stage          SponsorStage @default(PROSPECTING)
  valueInr       Int?
  notes          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model VolunteerApplication {
  id      String @id @default(cuid())
  userId  String
  eventId String
  role    String
  status  String @default("PENDING")
  hours   Int    @default(0)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  appliedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MerchInquiry {
  id               String        @id @default(cuid())
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  apparelType      String
  quantity         Int
  budget           String
  timeline         String
  city             String
  references       String[]
  stylePreferences String?
  status           MerchStatus   @default(INQUIRY_RECEIVED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Opportunity {
  id             String                 @id @default(cuid())
  organizationId String
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title          String
  type           OpportunityType
  location       String
  isRemote       Boolean                @default(false)
  description    String
  requirements   String[]
  skills         String[]
  stipend        String? // Monthly stipend in INR
  duration       String? // e.g., "3 months", "Summer 2026"
  startsAt       DateTime?
  endsAt         DateTime?
  applicationDeadline DateTime?
  positionsAvailable Int @default(1)
  applicationsCount  Int @default(0)
  featured       Boolean @default(false)
  active         Boolean @default(true)
  applications   OpportunityApplication[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model OpportunityApplication {
  id            String             @id @default(cuid())
  userId        String
  opportunityId String
  opportunity   Opportunity        @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        ApplicationStatus  @default(APPLIED)
  coverLetter   String?
  resumeUrl     String?
  portfolioUrl  String?
  appliedAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  // For organizer notes
  notes         String?
  interviewedAt DateTime?
  @@unique([userId, opportunityId])
}

model Announcement {
  id            String   @id @default(cuid())
  organizationId String
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title         String
  content       String
  published     Boolean  @default(false)
  publishedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Gallery {
  id            String   @id @default(cuid())
  organizationId String
  eventId       String?
  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event         Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull, name: "EventGalleries")
  title         String
  description   String?
  items         GalleryItem[] @relation("GalleryItemGallery")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model GalleryItem {
  id            String   @id @default(cuid())
  galleryId     String
  gallery       Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade, name: "GalleryItemGallery")
  url           String
  caption       String?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
}

model Notification {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          NotificationType
  title         String
  message       String
  data          Json?    // For additional data like eventId, opportunityId, etc.
  status        NotificationStatus @default(UNREAD)
  createdAt     DateTime @default(now())
  readAt        DateTime?
}

model Bookmark {
  id            String   @id @default(cuid())
  userId        String
  eventId       String?
  opportunityId String?
  organizationId String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserBookmarks")
  createdAt     DateTime @default(now())
  // Note: We enforce at least one reference in the application layer or via a check constraint if the database supports it.
  // For Prisma, we can use a check constraint in the migration, but we'll handle it in the service layer for simplicity.
}

model Certificate {
  id            String   @id @default(cuid())
  userId        String
  eventId       String?
  organizationId String?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "CertificateUser")
  event         Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull, name: "CertificateEvent")
  organization  Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull, name: "OrganizationCertificates")
  type          CertificateType
  title         String
  description   String?
  issuedAt      DateTime @default(now())
  certificateUrl String? // URL to PDF/image
  createdAt     DateTime @default(now())
}

model Follow {
  id            String   @id @default(cuid())
  followerId    String
  followingId   String
  follower      User     @relation("Follows", fields: [followerId], references: [id])
  following     User     @relation("Followers", fields: [followingId], references: [id])
  createdAt     DateTime @default(now())
  
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Comment {
  id            String   @id @default(cuid())
  userId        String
  eventId       String?
  opportunityId String?
  organizationId String?
  parentId      String?
  parent        Comment? @relation("Replies", fields: [parentId], references: [id])
  replies       Comment[] @relation("Replies")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserComments")
  reactions     Reaction[] @relation("CommentReactions")
  content       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([eventId])
  @@index([opportunityId])
  @@index([organizationId])
  @@index([parentId])
}

model Reaction {
  id            String   @id @default(cuid())
  userId        String
  commentId     String
  comment       Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade, name: "CommentReactions")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade, name: "UserReactions")
  type          String   // e.g., 'like', 'celebrate', 'support', 'insightful'
  createdAt     DateTime @default(now())
  
  @@unique([userId, commentId])
  @@index([commentId])
}