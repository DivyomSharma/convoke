generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("Convoke_PRISMA_DATABASE_URL")
  directUrl = env("Convoke_POSTGRES_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  displayName String?
  username   String?  @unique
  name       String?
  handle     String?  @unique
  bio        String?
  headline   String?
  avatarUrl  String?
  bannerUrl  String?
  role       String? // Student, Founder, Creator, Researcher, etc.
  pronouns   String?
  dob        DateTime?
  country    String?
  state      String?
  city       String?
  timezone   String?
  visibility String?
  themePreference String?
  university String?
  degree     String?
  graduationYear String?
  currentRole String?
  company    String?
  location   String?
  website    String?
  portfolio  String?
  github     String?
  linkedin   String?
  twitter    String?
  instagram  String?
  youtube    String?
  discord    String?
  telegram   String?
  phone      String?
  resumeUrl  String?
  onboardingCompleted Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships   Membership[]
  meets         MeetAttendance[]
  vouchesGiven  Vouch[]           @relation("VouchesGiven")
  vouchesRecv   Vouch[]           @relation("VouchesReceived")
  messages      Message[]
  notifications Notification[]
  applications  Application[]
  projects      Project[]
  research      Research[]
  bookmarks     Bookmark[]
  settings      Settings?
  sessions      Session[]
  activity      Activity[]
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  mission     String?  @db.Text
  vision      String?  @db.Text
  logoUrl     String?
  bannerUrl   String?
  industry    String?
  location    String?
  website     String?
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       Membership[]
  spaces        Space[]
  opportunities Opportunity[]
  faqs          FAQ[]
  sponsors      Sponsor[]
  gallery       GalleryImage[]
  timeline      TimelineEvent[]
  resources     Resource[]
  partners      Partner[]
  discord       String?
  instagram     String?
  whatsapp      String?
  twitter       String?
  linkedin      String?
}

model Membership {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           String // ADMIN, FOUNDER, MEMBER
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Space {
  id             String   @id @default(uuid())
  name           String
  description    String?  @db.Text
  bannerUrl      String?
  rules          String?  @db.Text
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  meets        Meet[]
  messages     Message[]
  discord      String?
  instagram    String?
  whatsapp     String?
  twitter      String?
  linkedin     String?
}

model Meet {
  id            String   @id @default(uuid())
  title         String
  description   String?  @db.Text
  bannerUrl     String?
  spaceId       String
  startTime     DateTime
  endTime       DateTime
  timezone      String?
  duration      Int? // minutes
  location      String?
  venue         String?
  requirements  String?  @db.Text
  difficulty    String?
  dressCode     String?
  parking       String?
  accessibility String?
  views         Int      @default(0)
  capacity      Int?
  waitlistCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  space      Space             @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  attendance MeetAttendance[]
  faqs       FAQ[]
  sponsors   Sponsor[]
  gallery    GalleryImage[]
  resources  Resource[]
  partners   Partner[]
  
  mode       String?
  discord    String?
  instagram  String?
  whatsapp   String?
  twitter    String?
  linkedin   String?
}

model MeetAttendance {
  id        String   @id @default(uuid())
  meetId    String
  userId    String
  status    String // GOING, INTERESTED, WAITLISTED
  createdAt DateTime @default(now())

  meet Meet @relation(fields: [meetId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetId, userId])
}

model Opportunity {
  id             String    @id @default(uuid())
  title          String
  type           String // ROLE, FELLOWSHIP, GRANT, HACKATHON/CHALLENGE
  description    String?   @db.Text
  department     String?
  employmentType String?
  jobType        String?
  remoteHybrid   String?
  openings       Int?
  experience     String?
  location       String?
  compensation   String?
  equity         String?
  benefits       String?   @db.Text
  stipend        String?
  bannerUrl      String?
  brochureUrl    String?
  mode           String?
  discord        String?
  instagram      String?
  whatsapp       String?
  twitter        String?
  linkedin       String?
  deadline       DateTime?
  views          Int       @default(0)
  organizationId String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  applications Application[]
  faqs         FAQ[]
  resources    Resource[]
}

model Application {
  id            String   @id @default(uuid())
  userId        String
  opportunityId String
  status        String // PENDING, ACCEPTED, REJECTED, INTERVIEW
  pitch         String?  @db.Text
  resumeUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  bannerUrl   String?
  url         String?
  demoUrl     String?
  githubUrl   String?
  figmaUrl    String?
  stack       String? // comma separated or JSON
  views       Int      @default(0)
  downloads   Int      @default(0)
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  faqs      FAQ[]
  gallery   GalleryImage[]
  timeline  TimelineEvent[]
  resources Resource[]
}

model Research {
  id        String   @id @default(uuid())
  title     String
  abstract  String?  @db.Text
  url       String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// UNIVERSAL DETAIL COMPONENTS
// ==========================================

model FAQ {
  id             String  @id @default(uuid())
  question       String
  answer         String  @db.Text
  meetId         String?
  organizationId String?
  opportunityId  String?
  projectId      String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  opportunity  Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Sponsor {
  id             String  @id @default(uuid())
  name           String
  logoUrl        String?
  tier           String?
  meetId         String?
  organizationId String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Partner {
  id             String  @id @default(uuid())
  name           String
  logoUrl        String?
  meetId         String?
  organizationId String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model GalleryImage {
  id             String  @id @default(uuid())
  url            String
  caption        String?
  meetId         String?
  organizationId String?
  projectId      String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TimelineEvent {
  id             String   @id @default(uuid())
  title          String
  date           DateTime
  description    String?  @db.Text
  organizationId String?
  projectId      String?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Resource {
  id             String  @id @default(uuid())
  name           String
  url            String
  type           String // PDF, LINK, VIDEO
  meetId         String?
  organizationId String?
  projectId      String?
  opportunityId  String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  opportunity  Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
}

// ==========================================
// EXISTING SYSTEM MODELS
// ==========================================

model Vouch {
  id         String   @id @default(uuid())
  giverId    String
  receiverId String
  content    String
  createdAt  DateTime @default(now())

  giver    User @relation("VouchesGiven", fields: [giverId], references: [id], onDelete: Cascade)
  receiver User @relation("VouchesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(uuid())
  content   String
  userId    String
  spaceId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  itemId    String // Polymorphic ID
  itemType  String // EVENT, OPPORTUNITY, etc.
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id          String   @id @default(uuid())
  userId      String   @unique
  theme       String   @default("system")
  emailNotifs Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(uuid())
  userId    String
  action    String
  metadata  String? // JSON string
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
