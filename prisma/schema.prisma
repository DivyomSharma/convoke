generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("Convoke_PRISMA_DATABASE_URL")
  directUrl = env("Convoke_POSTGRES_URL")
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  displayName String?
  username   String?  @unique
  name       String?
  handle     String?  @unique
  bio        String?
  headline   String?
  avatarUrl  String?
  bannerUrl  String?
  role       String? // Student, Founder, Creator, Researcher, etc.
  modes      String[] @default([])
  openTo     String[] @default([])
  pronouns   String?
  dob        DateTime?
  country    String?
  state      String?
  city       String?
  timezone   String?
  visibility String?
  themePreference String?
  university String?
  degree     String?
  graduationYear String?
  currentRole String?
  company    String?
  location   String?
  website    String?
  portfolio  String?
  github     String?
  linkedin   String?
  twitter    String?
  instagram  String?
  youtube    String?
  discord    String?
  telegram   String?
  phone      String?
  resumeUrl  String?
  onboardingCompleted Boolean @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  memberships   Membership[]
  meets         MeetAttendance[]
  vouchesGiven  Vouch[]           @relation("VouchesGiven")
  vouchesRecv   Vouch[]           @relation("VouchesReceived")
  notifications Notification[]
  applications  Application[]
  projects      Project[]
  research      Research[]
  bookmarks     Bookmark[]
  referralsGiven Referral[]
  settings      Settings?
  sessions      Session[]
  activity      Activity[]
  spaceMemberships SpaceMembership[]
  ledTeams      Team[]            @relation("TeamLeader")
  teamMemberships TeamMember[]
  teamRequests  TeamRequest[]
  follows       Follow[]          @relation("UserFollows")
  badges        Badge[]
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  mission     String?  @db.Text
  vision      String?  @db.Text
  logoUrl     String?
  bannerUrl   String?
  industry    String?
  location    String?
  website     String?
  views       Int      @default(0)
  
  // Organization Capabilities
  isRecruitingEnabled  Boolean @default(false)
  isSponsorshipEnabled Boolean @default(false)
  isMerchandiseEnabled Boolean @default(false)
  isResearchEnabled    Boolean @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       Membership[]
  spaces        Space[]
  opportunities Opportunity[]
  faqs          FAQ[]
  sponsors      Sponsor[]
  gallery       GalleryImage[]
  timeline      TimelineEvent[]
  resources     Resource[]
  partners      Partner[]
  discord       String?
  instagram     String?
  whatsapp      String?
  twitter       String?
  linkedin      String?
}

model Membership {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           String // ADMIN, FOUNDER, MEMBER
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Space {
  id             String   @id @default(uuid())
  name           String
  type           String?  @default("Community") // Club, Society, Chapter, Community, Circle, Collective
  description    String?  @db.Text
  bannerUrl      String?
  rules          String?  @db.Text
  organizationId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      SpaceMembership[]
  meets        Meet[]
  opportunities Opportunity[]
  projects     Project[]
  research     Research[]
  resources    Resource[]
  faqs         FAQ[]
  gallery      GalleryImage[]
  timeline     TimelineEvent[]
  discord      String?
  instagram    String?
  whatsapp     String?
  twitter      String?
  linkedin     String?
}

model Meet {
  id            String   @id @default(uuid())
  title         String
  description   String?  @db.Text
  bannerUrl     String?
  spaceId       String
  startTime     DateTime
  endTime       DateTime
  timezone      String?
  duration      Int? // minutes
  location      String?
  venue         String?
  requirements  String?  @db.Text
  difficulty    String?
  dressCode     String?
  parking       String?
  accessibility String?
  views         Int      @default(0)
  capacity      Int?
  waitlistCount Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  space      Space             @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  attendance MeetAttendance[]
  faqs       FAQ[]
  sponsors   Sponsor[]
  gallery    GalleryImage[]
  resources  Resource[]
  partners   Partner[]
  
  mode       String?
  discord    String?
  instagram  String?
  whatsapp   String?
  twitter    String?
  linkedin   String?
}

model MeetAttendance {
  id        String   @id @default(uuid())
  meetId    String
  userId    String
  status    String // GOING, INTERESTED, WAITLISTED
  createdAt DateTime @default(now())

  meet Meet @relation(fields: [meetId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetId, userId])
}

model Opportunity {
  id             String    @id @default(uuid())
  title          String
  type           String // ROLE, FELLOWSHIP, GRANT, HACKATHON/CHALLENGE
  participation  String?   // INDIVIDUAL, TEAM
  minTeamSize    Int?
  maxTeamSize    Int?
  crossCollegeTeams Boolean @default(false)
  teamFormationEnabled Boolean @default(false)
  description    String?   @db.Text
  department     String?
  employmentType String?
  jobType        String?
  remoteHybrid   String?
  openings       Int?
  experience     String?
  location       String?
  compensation   String?
  equity         String?
  benefits       String?   @db.Text
  stipend        String?
  bannerUrl      String?
  brochureUrl    String?
  mode           String?
  discord        String?
  instagram      String?
  whatsapp       String?
  twitter        String?
  linkedin       String?
  deadline       DateTime?
  views          Int       @default(0)
  organizationId String?
  spaceId        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  applications Application[]
  teams        Team[]
  faqs         FAQ[]
  resources    Resource[]
  referrals    Referral[]
}

model Application {
  id            String   @id @default(uuid())
  userId        String
  opportunityId String
  status        String // PENDING, ACCEPTED, REJECTED, INTERVIEW
  pitch         String?  @db.Text
  resumeUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  bannerUrl   String?
  url         String?
  demoUrl     String?
  githubUrl   String?
  figmaUrl    String?
  stack       String? // comma separated or JSON
  views       Int      @default(0)
  downloads   Int      @default(0)
  userId      String
  spaceId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  space     Space?          @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  faqs      FAQ[]
  gallery   GalleryImage[]
  timeline  TimelineEvent[]
  resources Resource[]
  buildLogs BuildLog[]
}

model Research {
  id        String   @id @default(uuid())
  title     String
  abstract  String?  @db.Text
  url       String?
  userId    String
  spaceId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space? @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

// ==========================================
// UNIVERSAL DETAIL COMPONENTS
// ==========================================

model FAQ {
  id             String  @id @default(uuid())
  question       String
  answer         String  @db.Text
  meetId         String?
  organizationId String?
  opportunityId  String?
  projectId      String?
  spaceId        String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  opportunity  Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Sponsor {
  id             String  @id @default(uuid())
  name           String
  logoUrl        String?
  tier           String?
  meetId         String?
  organizationId String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Partner {
  id             String  @id @default(uuid())
  name           String
  logoUrl        String?
  meetId         String?
  organizationId String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model GalleryImage {
  id             String  @id @default(uuid())
  url            String
  caption        String?
  meetId         String?
  organizationId String?
  projectId      String?
  spaceId        String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TimelineEvent {
  id             String   @id @default(uuid())
  title          String
  date           DateTime
  description    String?  @db.Text
  organizationId String?
  projectId      String?
  spaceId        String?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Resource {
  id             String  @id @default(uuid())
  name           String
  url            String
  type           String // PDF, LINK, VIDEO
  meetId         String?
  organizationId String?
  projectId      String?
  opportunityId  String?
  spaceId        String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  opportunity  Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
}

model BuildLog {
  id          String   @id @default(uuid())
  projectId   String
  summary     String
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Referral {
  id            String   @id @default(uuid())
  opportunityId String
  userId        String
  note          String?  @db.Text
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// EXISTING SYSTEM MODELS
// ==========================================

model Vouch {
  id         String   @id @default(uuid())
  giverId    String
  receiverId String
  content    String
  createdAt  DateTime @default(now())

  giver    User @relation("VouchesGiven", fields: [giverId], references: [id], onDelete: Cascade)
  receiver User @relation("VouchesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  itemId    String // Polymorphic ID
  itemType  String // EVENT, OPPORTUNITY, etc.
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id          String   @id @default(uuid())
  userId      String   @unique
  theme       String   @default("system")
  emailNotifs Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(uuid())
  userId    String
  action    String
  metadata  String? // JSON string
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SpaceMembership {
  id        String   @id @default(uuid())
  userId    String
  spaceId   String
  role      String   // Founder, Lead, Organizer, Core Team, Member, Alumni
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
}

model Team {
  id            String   @id @default(uuid())
  name          String
  opportunityId String
  leaderId      String
  about         String?  @db.Text
  lookingFor    String?  @db.Text // JSON or comma separated string of skills
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  leader      User        @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  members     TeamMember[]
  requests    TeamRequest[]
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      String?
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamRequest {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  status    String // PENDING, ACCEPTED, REJECTED
  type      String // APPLY, INVITE
  message   String?  @db.Text
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id         String   @id @default(uuid())
  followerId String
  targetId   String
  targetType String   // USER, SPACE, ORGANIZATION, PROJECT, RESEARCH
  createdAt  DateTime @default(now())

  follower   User     @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)

  @@unique([followerId, targetId, targetType])
}

model Badge {
  id          String   @id @default(uuid())
  name        String
  description String?
  iconUrl     String?
  userId      String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
