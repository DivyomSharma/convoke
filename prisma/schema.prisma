generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  STUDENT
  ORGANIZER
  FOUNDER
  CREATOR
  VOLUNTEER
  DEVELOPER
  DESIGNER
  PARTICIPANT
  COMMUNITY_ADMIN
  SPONSOR
  STARTUP
  PLATFORM_ADMIN
}

enum OrganizationType {
  STARTUP
  COMMUNITY
  COLLEGE_SOCIETY
  CREATOR_COLLECTIVE
  NGO
  BRAND
  SPONSOR
  PLATFORM
  AGENCY
}

enum MembershipRole {
  OWNER
  ADMIN
  OPERATOR
  VOLUNTEER_LEAD
  SPONSORSHIP_LEAD
  CREATOR_LEAD
  MEMBER
}

enum CommunityCategory {
  STARTUP
  COLLEGE
  CREATOR
  AI
  DESIGN
  OPEN_SOURCE
  GAMING
  SOCIAL_IMPACT
  NGO
}

enum EventMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
  CHECKED_IN
  CANCELLED
}

enum SponsorStage {
  PROSPECTING
  CONTACTED
  REPLIED
  NEGOTIATING
  CONFIRMED
}

enum MerchStatus {
  INQUIRY_RECEIVED
  REVIEWING
  QUOTATION_SENT
  WHATSAPP_CONTINUED
  PRODUCTION
  SHIPPED
  COMPLETED
}

enum OpportunityType {
  INTERNSHIP
  AMBASSADOR
  STARTUP_HIRING
  VOLUNTEER_ROLE
  CREATOR_COLLABORATION
  FREELANCE_GIG
}

enum ApplicationStatus {
  APPLIED
  REVIEWING
  SHORTLISTED
  INTERVIEW
  ACCEPTED
  REJECTED
}

enum TicketTypeCategory {
  GENERAL
  EARLY_BIRD
  VIP
  STUDENT
  GROUP
}

enum CertificateType {
  PARTICIPATION
  VOLUNTEER
  ORGANIZER
  BADGE
}

enum NotificationType {
  APPLICATION_UPDATE
  EVENT_REMINDER
  EVENT_UPDATE
  COMMUNITY_ANNOUNCEMENT
  VOLUNTEER_UPDATE
  SPONSOR_UPDATE
  MERCH_UPDATE
  STUDIO_UPDATE
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
}

enum StudioRequestType {
  BRANDING
  DEVELOPMENT
  DESIGN
  MVP_BUILD
  GROWTH_SETUP
}

model User {
  id                     String                   @id @default(cuid())
  clerkId                String                   @unique
  email                  String                   @unique
  username               String                   @unique
  displayName            String
  headline               String?
  bio                    String?
  avatarUrl              String?
  bannerUrl              String?
  city                   String?
  role                   UserRole                 @default(STUDENT)
  interests              String[]
  skills                 String[]
  badges                 String[]
  socials                Json?
  reputation             Int                      @default(0)
  onboardingDone         Boolean                  @default(false)
  experience             Json?
  projectsData           Json?

  memberships            Membership[]
  communityMemberships   CommunityMembership[]
  ledEvents              Event[]                  @relation("EventOwner")
  registrations          Registration[]
  waitlists              EventWaitlist[]
  volunteerApplications  VolunteerApplication[]
  opportunityApplications OpportunityApplication[]
  certificates           Certificate[]
  notifications          Notification[]
  bookmarks              Bookmark[]
  activities             UserActivity[]
  projects               Project[]
  teamMemberships        TeamMember[]
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
}

model Organization {
  id               String          @id @default(cuid())
  slug             String          @unique
  name             String
  type             OrganizationType
  description      String
  website          String?
  city             String?
  state            String?
  logoUrl          String?
  bannerUrl        String?
  verified         Boolean         @default(false)
  communities      Community[]
  memberships      Membership[]
  events           Event[]
  opportunities    Opportunity[]
  announcements    Announcement[]
  galleries        Gallery[]
  sponsorLeads     SponsorLead[]
  merchInquiries   MerchInquiry[]
  studioRequests   StudioRequest[]
  teamMembers      TeamMember[]
  teams            Team[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)
  title          String?
  joinedAt       DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Community {
  id                 String                @id @default(cuid())
  slug               String                @unique
  organizationId     String
  name               String
  category           CommunityCategory
  tagline            String
  description        String
  city               String
  isFeatured         Boolean               @default(false)
  coverImageUrl      String?
  memberCount        Int                   @default(0)
  momentumScore      Int                   @default(0)
  organization       Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members            CommunityMembership[]
  events             Event[]
  opportunities      Opportunity[]
  announcements      Announcement[]
  teams              Team[]
  activities         UserActivity[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
}

model CommunityMembership {
  id          String         @id @default(cuid())
  userId      String
  communityId String
  role        MembershipRole @default(MEMBER)
  joinedAt    DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  community   Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
}

model Team {
  id            String       @id @default(cuid())
  communityId    String?
  eventId        String?
  organizationId String?
  name           String
  purpose        String
  community      Community?   @relation(fields: [communityId], references: [id], onDelete: SetNull)
  event          Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  members        TeamMember[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model TeamMember {
  id             String         @id @default(cuid())
  teamId          String
  userId          String
  organizationId  String?
  role            MembershipRole @default(MEMBER)
  team            Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization    Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([teamId, userId])
}

model Event {
  id                   String                 @id @default(cuid())
  slug                 String                 @unique
  organizationId       String
  communityId          String?
  organizerId          String?
  title                String
  shortDescription     String
  description          String
  city                 String
  venue                String?
  category             String
  mode                 EventMode
  startsAt             DateTime
  endsAt               DateTime
  heroImageUrl         String?
  isPaid               Boolean                @default(false)
  approvalBased        Boolean                @default(false)
  featured             Boolean                @default(false)
  certificateEnabled   Boolean                @default(true)
  registrationsCount   Int                    @default(0)
  waitlistCount        Int                    @default(0)
  volunteerCount       Int                    @default(0)
  organization         Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  community            Community?             @relation(fields: [communityId], references: [id], onDelete: SetNull)
  organizer            User?                  @relation("EventOwner", fields: [organizerId], references: [id], onDelete: SetNull)
  registrations        Registration[]
  waitlistEntries      EventWaitlist[]
  ticketTypes          TicketType[]
  schedules            EventSchedule[]
  tracks               EventTrack[]
  faqs                 EventFaq[]
  speakers             EventSpeaker[]
  judges               EventJudge[]
  sponsors             EventSponsor[]
  volunteerApplications VolunteerApplication[]
  announcements        Announcement[]
  teams                Team[]
  galleries            Gallery[]
  sponsorLeads         SponsorLead[]
  certificates         Certificate[]
  activities           UserActivity[]
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
}

model TicketType {
  id        String             @id @default(cuid())
  eventId   String
  name      String
  category  TicketTypeCategory @default(GENERAL)
  priceInr  Int                @default(0)
  capacity  Int?
  sold      Int                @default(0)
  event     Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations Registration[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
}

model Registration {
  id           String             @id @default(cuid())
  userId       String
  eventId      String
  ticketTypeId String?
  status       RegistrationStatus @default(PENDING)
  qrCode       String             @unique
  checkedInAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  event        Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketType   TicketType?        @relation(fields: [ticketTypeId], references: [id], onDelete: SetNull)

  @@unique([userId, eventId])
}

model EventWaitlist {
  id        String   @id @default(cuid())
  userId     String
  eventId    String
  reason     String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model EventTrack {
  id          String   @id @default(cuid())
  eventId      String
  name         String
  description  String?
  order        Int      @default(0)
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventSchedule {
  id          String   @id @default(cuid())
  eventId      String
  title        String
  description  String?
  startsAt     DateTime
  endsAt       DateTime
  location     String?
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventFaq {
  id          String   @id @default(cuid())
  eventId      String
  question     String
  answer       String
  order        Int      @default(0)
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventSpeaker {
  id           String   @id @default(cuid())
  eventId       String
  name          String
  title         String?
  organization  String?
  bio           String?
  avatarUrl     String?
  talkTitle     String?
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventJudge {
  id           String   @id @default(cuid())
  eventId       String
  name          String
  title         String?
  organization  String?
  bio           String?
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventSponsor {
  id             String        @id @default(cuid())
  eventId         String
  name            String
  tier            String
  logoUrl         String?
  benefits        String[]
  event           Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model VolunteerApplication {
  id         String             @id @default(cuid())
  userId      String
  eventId     String
  role        String
  status      ApplicationStatus @default(APPLIED)
  hours       Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  event       Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId, role])
}

model Opportunity {
  id                    String                    @id @default(cuid())
  slug                  String                    @unique
  organizationId        String
  communityId           String?
  title                 String
  type                  OpportunityType
  location              String
  isRemote              Boolean                   @default(false)
  shortDescription      String
  description           String
  requirements          String[]
  skills                String[]
  perks                 String[]
  stipend               String?
  duration              String?
  applicationDeadline   DateTime?
  positionsAvailable    Int                       @default(1)
  featured              Boolean                   @default(false)
  active                Boolean                   @default(true)
  organization          Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  community             Community?                @relation(fields: [communityId], references: [id], onDelete: SetNull)
  applications          OpportunityApplication[]
  activities            UserActivity[]
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
}

model OpportunityApplication {
  id             String             @id @default(cuid())
  userId          String
  opportunityId   String
  status          ApplicationStatus @default(APPLIED)
  coverLetter     String?
  resumeUrl       String?
  portfolioUrl    String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity     Opportunity       @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@unique([userId, opportunityId])
}

model Announcement {
  id             String       @id @default(cuid())
  organizationId String
  communityId    String?
  eventId        String?
  title          String
  content        String
  publishedAt    DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  community      Community?   @relation(fields: [communityId], references: [id], onDelete: SetNull)
  event          Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model Gallery {
  id             String        @id @default(cuid())
  organizationId String
  eventId        String?
  title          String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  items          GalleryItem[]
}

model GalleryItem {
  id         String   @id @default(cuid())
  galleryId   String
  url         String
  caption     String?
  order       Int      @default(0)
  gallery     Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)
}

model SponsorLead {
  id             String       @id @default(cuid())
  organizationId String
  eventId        String?
  companyName    String
  contactEmail   String
  stage          SponsorStage @default(PROSPECTING)
  valueInr       Int?
  notes          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model MerchInquiry {
  id               String       @id @default(cuid())
  organizationId   String?
  apparelType      String
  quantity         Int
  budget           String
  timeline         String
  city             String
  references       String[]
  stylePreferences String?
  status           MerchStatus  @default(INQUIRY_RECEIVED)
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model StudioRequest {
  id               String            @id @default(cuid())
  organizationId   String?
  type             StudioRequestType
  title            String
  brief            String
  status           NotificationStatus @default(UNREAD)
  organization     Organization?      @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Project {
  id           String   @id @default(cuid())
  userId        String
  organizationId String?
  name         String
  description  String
  url          String?
  technologies String[]
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Certificate {
  id             String          @id @default(cuid())
  userId          String
  eventId         String?
  type            CertificateType
  title           String
  description     String?
  certificateUrl  String?
  issuedAt        DateTime        @default(now())
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  event           Event?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
}

model Notification {
  id          String              @id @default(cuid())
  userId       String
  type         NotificationType
  title        String
  message      String
  status       NotificationStatus @default(UNREAD)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  readAt       DateTime?
}

model Bookmark {
  id             String   @id @default(cuid())
  userId          String
  eventId         String?
  opportunityId   String?
  communityId     String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}

model UserActivity {
  id           String      @id @default(cuid())
  userId        String
  communityId   String?
  eventId       String?
  opportunityId String?
  actorName     String
  action        String
  detail        String
  createdAt     DateTime   @default(now())
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  community     Community? @relation(fields: [communityId], references: [id], onDelete: SetNull)
  event         Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
}
