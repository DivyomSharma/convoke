generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("Convoke_PRISMA_DATABASE_URL")
  directUrl = env("Convoke_POSTGRES_URL")
}

enum PublishStatus {
  DRAFT
  PREVIEW
  REVIEW
  PUBLISHED
  ARCHIVED
  DELETED
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  displayName         String?
  username            String?   @unique
  name                String?
  handle              String?   @unique
  bio                 String?
  headline            String?
  avatarUrl           String?
  bannerUrl           String?
  role                String? // Student, Founder, Creator, Researcher, etc.
  modes               String[]  @default([])
  openTo              String[]  @default([])
  skills              String[]  @default([])
  languages           String[]  @default([])
  pronouns            String?
  dob                 DateTime?
  country             String?
  state               String?
  city                String?
  timezone            String?
  visibility          String?
  themePreference     String?
  university          String?
  degree              String?
  graduationYear      String?
  currentRole         String?
  company             String?
  location            String?
  website             String?
  portfolio           String?
  github              String?
  linkedin            String?
  twitter             String?
  instagram           String?
  youtube             String?
  discord             String?
  telegram            String?
  phone               String?
  resumeUrl           String?
  onboardingCompleted Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  memberships         Membership[]
  meets               MeetAttendance[]
  vouchesGiven        Vouch[]                   @relation("VouchesGiven")
  vouchesRecv         Vouch[]                   @relation("VouchesReceived")
  notifications       Notification[]
  applications        Application[]
  projects            Project[]
  research            Research[]
  bookmarks           Bookmark[]
  referralsGiven      Referral[]
  experiences         Experience[]
  educations          Education[]
  achievements        Achievement[]
  settings            Settings?
  sessions            Session[]
  activity            Activity[]
  spaceMemberships    SpaceMembership[]
  ledTeams            Team[]                    @relation("TeamLeader")
  teamMemberships     TeamMember[]
  teamRequests        TeamRequest[]
  follows             Follow[]                  @relation("UserFollows")
  badges              Badge[]
  certificates        Certificate[]
  conversations       ConversationParticipant[]
  messagesSent        Message[]
  meetApplications    MeetApplication[]
  sponsorshipRequests SponsorshipRequest[]
  introsRequested     IntroductionRequest[]     @relation("IntroRequester")
  introsReceived      IntroductionRequest[]     @relation("IntroTarget")
}

model Certificate {
  id        String   @id @default(uuid())
  userId    String
  title     String
  issuer    String
  issueDate DateTime
  url       String?
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  mission     String? @db.Text
  vision      String? @db.Text
  logoUrl     String?
  bannerUrl   String?
  industry    String?
  location    String?
  website     String?
  views       Int     @default(0)
  status      PublishStatus @default(DRAFT)

  // Organization Capabilities
  isRecruitingEnabled  Boolean @default(false)
  isSponsorshipEnabled Boolean @default(false)
  isMerchandiseEnabled Boolean @default(false)
  isResearchEnabled    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members                 Membership[]
  spaces                  Space[]
  opportunities           Opportunity[]
  faqs                    FAQ[]
  sponsors                Sponsor[]
  gallery                 GalleryImage[]
  timeline                TimelineEvent[]
  resources               Resource[]
  partners                Partner[]
  discord                 String?
  instagram               String?
  whatsapp                String?
  twitter                 String?
  linkedin                String?
  
  sponsorIndustries       String?
  sponsorBudgetRange      String?
  sponsorAudience         String?
  sponsorPastSponsorships String?
  sponsorContactEmail     String?

  challenges              Challenge[]
  sponsorshipRequests     SponsorshipRequest[] @relation("SponsorInbox")
  initiatedCollaborations Collaboration[]      @relation("InitiatedCollaborations")
  targetCollaborations    Collaboration[]      @relation("TargetCollaborations")

  notifications            Notification[]
  conversationParticipants ConversationParticipant[]
  messagesSent             Message[]

  sponsorshipRequestsInitiated SponsorshipRequest[] @relation("SponsorRequesterOrg")
  communityDrops               CommunityDrop[]
  category                     String[]             @default([])
  region                       String?
}

model Membership {
  id             String   @id @default(uuid())
  userId         String
  organizationId String
  role           String // ADMIN, FOUNDER, MEMBER
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Space {
  id             String   @id @default(uuid())
  name           String
  type           String?  @default("Community") // Club, Society, Chapter, Community, Circle, Collective
  description    String?  @db.Text
  bannerUrl      String?
  rules          String?  @db.Text
  organizationId String?
  status         PublishStatus @default(DRAFT)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members       SpaceMembership[]
  meets         Meet[]
  opportunities Opportunity[]
  challenges    Challenge[]
  projects      Project[]
  research      Research[]
  resources     Resource[]
  faqs          FAQ[]
  gallery       GalleryImage[]
  timeline      TimelineEvent[]
  discord       String?
  instagram     String?
  whatsapp      String?
  twitter       String?
  linkedin      String?

  notifications            Notification[]
  conversationParticipants ConversationParticipant[]
  messagesSent             Message[]

  category                String[]             @default([])
  region                  String?
  sponsorshipRequests     SponsorshipRequest[]
  initiatedCollaborations Collaboration[]      @relation("InitiatedSpaceCollaborations")
  targetCollaborations    Collaboration[]      @relation("TargetSpaceCollaborations")
  communityDrops          CommunityDrop[]
}

model Meet {
  id            String   @id @default(uuid())
  title         String
  description   String?  @db.Text
  bannerUrl     String?
  spaceId       String
  startTime     DateTime
  endTime       DateTime
  timezone      String?
  duration      Int? // minutes
  location      String?
  venue         String?
  requirements  String?  @db.Text
  difficulty    String?
  dressCode     String?
  parking       String?
  accessibility String?
  views         Int      @default(0)
  capacity      Int?
  waitlistCount Int      @default(0)
  status        PublishStatus @default(DRAFT)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  space        Space             @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  attendance   MeetAttendance[]
  applications MeetApplication[]
  faqs         FAQ[]
  sponsors     Sponsor[]
  gallery      GalleryImage[]
  resources    Resource[]
  partners     Partner[]

  mode      String?
  discord   String?
  instagram String?
  whatsapp  String?
  twitter   String?
  linkedin  String?

  category              String[] @default([])
  region                String?
  hasEventKit           Boolean  @default(false)
  hasOfficialCollection Boolean  @default(false)

  sponsorshipRequests SponsorshipRequest[]
  communityDrops      CommunityDrop[]
}

model MeetAttendance {
  id        String   @id @default(uuid())
  meetId    String
  userId    String
  status    String // GOING, CANCELLED
  role      String   @default("ATTENDEE") // ATTENDEE, SPEAKER, SPONSOR, VOLUNTEER, VIP, ORGANIZER
  createdAt DateTime @default(now())

  meet Meet @relation(fields: [meetId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetId, userId])
}

model MeetApplication {
  id        String   @id @default(uuid())
  meetId    String
  userId    String
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  answers   String?  @db.Text
  createdAt DateTime @default(now())

  meet Meet @relation(fields: [meetId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetId, userId])
}

model Opportunity {
  id                   String    @id @default(uuid())
  title                String
  type                 String // INTERNSHIP, JOB, VOLUNTEER, GRANT, FELLOWSHIP, OPEN_CALL, RESIDENCY, SCHOLARSHIP, RESEARCH_ASSISTANT, TEACHING_ASSISTANT
  description          String?   @db.Text
  department           String?
  employmentType       String?
  jobType              String?
  remoteHybrid         String?
  openings             Int?
  experience           String?
  location             String?
  compensation         String?
  equity               String?
  benefits             String?   @db.Text
  stipend              String?
  bannerUrl            String?
  brochureUrl          String?
  mode                 String?
  discord              String?
  instagram            String?
  whatsapp             String?
  twitter              String?
  linkedin             String?
  deadline             DateTime?
  views                Int       @default(0)
  organizationId       String?
  spaceId              String?
  status               PublishStatus @default(DRAFT)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  applications Application[]
  faqs         FAQ[]
  resources    Resource[]
  referrals    Referral[]
  category     String[]      @default([])
  region       String?
}

model Challenge {
  id                   String    @id @default(uuid())
  name                 String
  slug                 String    @unique
  description          String?   @db.Text
  startDate            DateTime?
  endDate              DateTime?
  type                 String? // Hackathon, Competition, Innovation Challenge, Bounty, Case Competition
  participation        String? // INDIVIDUAL, TEAM
  minTeamSize          Int?
  maxTeamSize          Int?
  crossCollegeTeams    Boolean   @default(false)
  teamFormationEnabled Boolean   @default(false)
  location             String?
  mode                 String? // In-person, Virtual, Hybrid
  bannerUrl            String?
  discord              String?
  twitter              String?
  website              String?
  views                Int       @default(0)
  organizationId       String
  spaceId              String?
  status               PublishStatus @default(DRAFT)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space               Space?               @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  sponsorshipRequests SponsorshipRequest[]
  communityDrops      CommunityDrop[]
  teams               Team[]
  applications        Application[]
  faqs                FAQ[]
  resources           Resource[]
}

model Application {
  id            String   @id @default(uuid())
  userId        String
  opportunityId String?
  challengeId   String?
  status        String // PENDING, ACCEPTED, REJECTED, INTERVIEW
  pitch         String?  @db.Text
  resumeUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  challenge   Challenge?   @relation(fields: [challengeId], references: [id], onDelete: Cascade)
}

model Project {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  bannerUrl   String?
  url         String?
  demoUrl     String?
  githubUrl   String?
  figmaUrl    String?
  stack       String? // comma separated or JSON
  views       Int      @default(0)
  downloads   Int      @default(0)
  userId      String
  spaceId     String?
  challengeId String?
  status      PublishStatus @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  space     Space?          @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  faqs      FAQ[]
  gallery   GalleryImage[]
  timeline  TimelineEvent[]
  resources Resource[]
  buildLogs BuildLog[]
  category  String[]        @default([])
  region    String?
  teams     Team[]
}

model Research {
  id        String   @id @default(uuid())
  title     String
  abstract  String?  @db.Text
  url       String?
  userId    String
  spaceId   String?
  projectId String?
  status    PublishStatus @default(DRAFT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  space    Space?   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  category String[] @default([])
  region   String?
}

// ==========================================
// UNIVERSAL DETAIL COMPONENTS
// ==========================================

model FAQ {
  id             String  @id @default(uuid())
  question       String
  answer         String  @db.Text
  meetId         String?
  organizationId String?
  opportunityId  String?
  challengeId    String?
  projectId      String?
  spaceId        String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  opportunity  Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  challenge    Challenge?    @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Sponsor {
  id             String  @id @default(uuid())
  name           String
  logoUrl        String?
  tier           String?
  meetId         String?
  organizationId String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Partner {
  id             String  @id @default(uuid())
  name           String
  logoUrl        String?
  meetId         String?
  organizationId String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model GalleryImage {
  id             String  @id @default(uuid())
  url            String
  caption        String?
  meetId         String?
  organizationId String?
  projectId      String?
  spaceId        String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model TimelineEvent {
  id             String   @id @default(uuid())
  title          String
  date           DateTime
  description    String?  @db.Text
  organizationId String?
  projectId      String?
  spaceId        String?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Resource {
  id             String  @id @default(uuid())
  name           String
  url            String
  type           String // PDF, LINK, VIDEO
  meetId         String?
  organizationId String?
  projectId      String?
  opportunityId  String?
  challengeId    String?
  spaceId        String?

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  opportunity  Opportunity?  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  challenge    Challenge?    @relation(fields: [challengeId], references: [id], onDelete: Cascade)
}

model BuildLog {
  id        String   @id @default(uuid())
  projectId String
  summary   String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Referral {
  id            String   @id @default(uuid())
  opportunityId String
  userId        String
  note          String?  @db.Text
  createdAt     DateTime @default(now())

  opportunity Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// EXISTING SYSTEM MODELS
// ==========================================

model Vouch {
  id         String   @id @default(uuid())
  giverId    String
  receiverId String
  content    String
  createdAt  DateTime @default(now())

  giver    User @relation("VouchesGiven", fields: [giverId], references: [id], onDelete: Cascade)
  receiver User @relation("VouchesReceived", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Notification {
  id             String   @id @default(uuid())
  userId         String
  organizationId String?
  spaceId        String?
  type           String
  content        String
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  itemId    String // Polymorphic ID
  itemType  String // EVENT, OPPORTUNITY, etc.
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id          String   @id @default(uuid())
  userId      String   @unique
  theme       String   @default("system")
  emailNotifs Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(uuid())
  userId    String
  action    String
  metadata  String? // JSON string
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SpaceMembership {
  id        String   @id @default(uuid())
  userId    String
  spaceId   String
  role      String // Founder, Lead, Organizer, Core Team, Member, Alumni
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
}

model Team {
  id            String   @id @default(uuid())
  name          String
  avatarUrl     String?
  challengeId   String?
  projectId     String?
  leaderId      String
  about         String?  @db.Text
  lookingFor    String?  @db.Text // JSON or comma separated string of skills
  status        PublishStatus @default(DRAFT)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  challenge   Challenge?    @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  leader      User          @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  members     TeamMember[]
  requests    TeamRequest[]
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      String   @default("MEMBER") // LEADER, CO_LEADER, MEMBER, MENTOR, JUDGE, VOLUNTEER
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamRequest {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  status    String // PENDING, ACCEPTED, REJECTED, WITHDRAWN
  type      String // APPLY, INVITE
  message   String?  @db.Text
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  id         String   @id @default(uuid())
  followerId String
  targetId   String
  targetType String // USER, SPACE, ORGANIZATION, PROJECT, RESEARCH
  createdAt  DateTime @default(now())

  follower User @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)

  @@unique([followerId, targetId, targetType])
}

model Badge {
  id          String   @id @default(uuid())
  name        String
  description String?
  iconUrl     String?
  userId      String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// MESSAGING
// ==========================================

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isGroup   Boolean  @default(false)
  name      String?

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  organizationId String?
  spaceId        String?
  joinedAt       DateTime @default(now())
  hasMuted       Boolean  @default(false)
  hasArchived    Boolean  @default(false)
  status         String   @default("ACCEPTED") // PENDING, ACCEPTED, REJECTED, BLOCKED

  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId, organizationId, spaceId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  senderOrgId    String?
  senderSpaceId  String?
  content        String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderOrg    Organization? @relation(fields: [senderOrgId], references: [id], onDelete: Cascade)
  senderSpace  Space?        @relation(fields: [senderSpaceId], references: [id], onDelete: Cascade)
}

model Experience {
  id          String    @id @default(uuid())
  company     String
  role        String
  type        String
  startDate   DateTime
  endDate     DateTime?
  description String?   @db.Text
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Education {
  id           String    @id @default(uuid())
  school       String
  degree       String?
  field        String?
  startDate    DateTime?
  endDate      DateTime?
  grade        String?
  achievements String?   @db.Text
  userId       String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id          String    @id @default(uuid())
  title       String
  type        String
  date        DateTime?
  description String?   @db.Text
  url         String?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SponsorshipRequest {
  id          String   @id @default(uuid())
  title       String?
  description String?  @db.Text
  requestType String[] @default([])

  requesterId      String?
  requesterSpaceId String?
  requesterOrgId   String?

  sponsorId String?

  meetId      String?
  challengeId String?

  audienceSize String?
  college      String?
  budget       String?
  timeline     String?
  location     String?

  deliverables String?  @db.Text
  benefits     String?  @db.Text
  assetsUrl    String?
  socialLinks  String?
  deckUrl      String?
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  requester      User?         @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  requesterSpace Space?        @relation(fields: [requesterSpaceId], references: [id], onDelete: Cascade)
  requesterOrg   Organization? @relation("SponsorRequesterOrg", fields: [requesterOrgId], references: [id], onDelete: Cascade)

  sponsor   Organization? @relation("SponsorInbox", fields: [sponsorId], references: [id], onDelete: Cascade)
  meet      Meet?         @relation(fields: [meetId], references: [id], onDelete: SetNull)
  challenge Challenge?    @relation(fields: [challengeId], references: [id], onDelete: SetNull)
}

model Collaboration {
  id    String  @id @default(uuid())
  title String?
  type  String?

  initiatorOrgId   String?
  initiatorSpaceId String?
  targetOrgId      String?
  targetSpaceId    String?

  status    String   @default("REQUESTED") // REQUESTED, REVIEWING, ACCEPTED, DECLINED, COMPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  initiatorOrg   Organization? @relation("InitiatedCollaborations", fields: [initiatorOrgId], references: [id], onDelete: Cascade)
  targetOrg      Organization? @relation("TargetCollaborations", fields: [targetOrgId], references: [id], onDelete: Cascade)
  initiatorSpace Space?        @relation("InitiatedSpaceCollaborations", fields: [initiatorSpaceId], references: [id], onDelete: Cascade)
  targetSpace    Space?        @relation("TargetSpaceCollaborations", fields: [targetSpaceId], references: [id], onDelete: Cascade)
}

model IntroductionRequest {
  id          String   @id @default(uuid())
  requesterId String
  targetId    String
  reason      String
  opportunity String?  @db.Text
  note        String?  @db.Text
  status      String   @default("PENDING") // PENDING, ACCEPTED, IGNORED
  createdAt   DateTime @default(now())

  requester User @relation("IntroRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target    User @relation("IntroTarget", fields: [targetId], references: [id], onDelete: Cascade)
}

model CommunityDrop {
  id          String  @id @default(uuid())
  title       String
  description String? @db.Text
  type        String // OfficialCollection, EventKit, Drop
  imageUrl    String?
  url         String?

  meetId         String?
  challengeId    String?
  spaceId        String?
  organizationId String?
  
  status PublishStatus @default(DRAFT)

  createdAt DateTime @default(now())

  meet         Meet?         @relation(fields: [meetId], references: [id], onDelete: Cascade)
  challenge    Challenge?    @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  space        Space?        @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
