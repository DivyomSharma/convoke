generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ATTENDEE
  ORGANIZER
  VOLUNTEER
  SPONSOR
  NGO
  CREATOR
  STARTUP_COMMUNITY
  ADMIN
}

enum EventMode {
  ONLINE
  OFFLINE
  HYBRID
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
  CHECKED_IN
}

enum SponsorStage {
  PROSPECTING
  CONTACTED
  REPLIED
  NEGOTIATING
  CONFIRMED
  COMPLETED
}

enum MerchStatus {
  INQUIRY_RECEIVED
  REVIEWING
  QUOTATION_SENT
  PRODUCTION
  SHIPPED
  COMPLETED
}

model User {
  id            String                 @id @default(cuid())
  clerkId       String?                @unique
  email         String                 @unique
  username      String                 @unique
  name          String
  headline      String?
  imageUrl      String?
  role          UserRole               @default(ATTENDEE)
  profile       Profile?
  memberships   Membership[]
  registrations Registration[]
  volunteerApps VolunteerApplication[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model Profile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String?
  linkedinUrl   String?
  discordHandle String?
  githubUrl     String?
  twitterUrl    String?
  instagramUrl  String?
  youtubeUrl    String?
  portfolioUrl  String?
  skills        String[]
  badges        String[]
  reputation    Float    @default(0)
}

model Organization {
  id             String         @id @default(cuid())
  slug           String         @unique
  name           String
  type           String
  description    String?
  members        Membership[]
  events         Event[]
  sponsorLeads   SponsorLead[]
  merchInquiries MerchInquiry[]
  createdAt      DateTime       @default(now())
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Event {
  id             String                 @id @default(cuid())
  organizationId String
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  slug           String                 @unique
  title          String
  category       String
  city           String
  mode           EventMode
  startsAt       DateTime
  endsAt         DateTime?
  isPaid         Boolean                @default(false)
  inviteOnly     Boolean                @default(false)
  approvalBased  Boolean                @default(false)
  heroImageUrl   String?
  blocks         Json
  registrations  Registration[]
  sponsorLeads   SponsorLead[]
  volunteerApps  VolunteerApplication[]
  ticketTypes    TicketType[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model TicketType {
  id       String @id @default(cuid())
  eventId  String
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name     String
  priceInr Int    @default(0)
  capacity Int?
}

model Registration {
  id           String             @id @default(cuid())
  userId       String
  eventId      String
  ticketTypeId String?
  status       RegistrationStatus @default(PENDING)
  qrCode       String             @unique
  tags         String[]
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  event        Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
}

model SponsorLead {
  id             String       @id @default(cuid())
  organizationId String
  eventId        String?
  companyName    String
  contactEmail   String
  stage          SponsorStage @default(PROSPECTING)
  valueInr       Int?
  notes          String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model VolunteerApplication {
  id      String @id @default(cuid())
  userId  String
  eventId String
  role    String
  status  String @default("PENDING")
  hours   Int    @default(0)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model MerchInquiry {
  id               String        @id @default(cuid())
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  apparelType      String
  quantity         Int
  budget           String
  timeline         String
  city             String
  references       String[]
  stylePreferences String?
  status           MerchStatus   @default(INQUIRY_RECEIVED)
  createdAt        DateTime      @default(now())
}
